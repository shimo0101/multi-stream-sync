{
  "manifest_version": 3,
  "name": "MultiStream Sync",
  "version": "0.1.0",
  "description": "YouTubeとTwitchを同時視聴。ニコニコ風コメント流し・配信開始時刻基準の手動同期に対応。",
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  },
  "action": {
    "default_title": "MultiStream Sync を開く",
    "default_icon": {
      "48": "icons/icon-48.png"
    }
  },
  "background": {
    "scripts": ["background.js"]
  },
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [],
  "browser_specific_settings": {
    "gecko": {
      "id": "multi-stream-sync@local",
      "strict_min_version": "109.0"
    },
    "gecko_android": {
      "strict_min_version": "120.0"
    }
  }
}
